---
import Footer from "@/components/common/Footer.astro";
import TopBar from "@/components/common/TopBar.astro";
import About from "@/components/landing/About.astro";
import Bento from "@/components/landing/Bento.astro";
import Experience from "@/components/landing/Experience.astro";
import Jumbo from "@/components/landing/Jumbo.astro";
import Skills from "@/components/landing/Skills.astro";
import Html from "@/layouts/Html.astro";
---

<Html>
  <TopBar />
  <main class="container mx-auto px-8 flex flex-col gap-32">
    <Jumbo />
    <Bento />
    <About />
    <Skills />
    <Experience />
    <Footer />
  </main>
</Html>

<script define:vars={{ path: Astro.url.pathname }}>
  gtag("event", "page_view", {
    page_title: "landing",
    page_path: path,
  });
</script>
