---
import Html from "@/ui/layouts/Html.astro";
---

<Html title="Miner Feber">
  <canvas
    width="768"
    height={(16 * 768) / 9}
    class="mx-auto w-full max-w-screen-sm h-[100dvh]"></canvas>
</Html>

<script>
  const canvas = document.querySelector("canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d") as CanvasRenderingContext2D;

  const state = {
    bulletSpeed: 4 * 1,
    shootCadence: 8 * 10,
  };

  const stage = {
    x: 0,
    y: 0,
    w: canvas.width,
    h: canvas.height,
    draw() {
      ctx.fillStyle = "lime";
      ctx.fillRect(this.x, this.y, this.w, this.h);
    },
  };

  const miner = {
    x: canvas.width / 2 - 40,
    y: canvas.height - (8 * 8 + 80),
    w: 80,
    h: 80,
    color: "red",
    draw() {
      ctx.fillStyle = this.color;
      ctx.fillRect(this.x, this.y, this.w, this.h);
    },
  };

  const bullet = () => ({
    x: miner.x + miner.w / 2,
    y: miner.y + miner.h / 2,
    w: 16,
    h: 16,
    color: "white",
    draw() {
      ctx.fillStyle = this.color;
      ctx.fillRect(this.x, this.y, this.w, this.h);
    },
    move() {
      this.y -= state.bulletSpeed;

      if (this.y < -20) {
        bullets.splice(bullets.indexOf(this), 1);
      }

      this.draw();
    },
  });

  const rock = () => {
    const direction = Math.random() < 0.5 ? 'left' : 'right';
    const speed = Math.random() * 2 + 1;

    return {
      x: Math.random() * canvas.width,
      y: 0,
      r: Math.floor(Math.random() * (180 - 40 + 1) + 40),
      dir: direction,
      color: "gray",
      draw() {
        ctx.fillStyle = this.color;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, 2 * Math.PI);
        ctx.fill();
      },
      move() {
        if (this.dir === 'left') {
          this.x -= speed;
        } else {
          this.x += speed;
        }

        this.y += speed;

        if ((this.x - (this.r / 2)) < 0 || (this.x + (this.r / 2)) > canvas.width) {
          this.dir = this.dir === 'left' ? 'right' : 'left';
        }

        if ((this.y - this.r) > canvas.height) {
          rocks.splice(rocks.indexOf(this), 1);
        }

        this.draw();
      },
    };
  };

  const bullets: ReturnType<typeof bullet>[] = [];
  const rocks: ReturnType<typeof rock>[] = [];

  const frame = () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stage.draw();
    miner.draw();

    for (const bullet of bullets) {
      bullet.move();
    }

    for (const rock of rocks) {
      rock.move();
    }

    requestAnimationFrame(frame);
  };

  requestAnimationFrame(frame);

  const moveMinerLeftRight = (e: MouseEvent | TouchEvent) => {
    const touch = e as TouchEvent;
    const mouse = e as MouseEvent;
    const x = miner.x + mouse.movementX * 1.9;

    if (touch.touches) {
      const tch = touch.touches[0] as Touch;
      miner.x = tch.clientX * 2 - miner.w;
    }

    if (x < 0) miner.x = 16;
    if (x > canvas.width - miner.w) miner.x = canvas.width - miner.w - 16;
    if (x > 0 && x < canvas.width - miner.w) miner.x = x;
  };

  let shotter: NodeJS.Timeout;
  let rockSpawner: NodeJS.Timeout;

  const shoot = () => {
    bullets.push(bullet());
  };

  const spawnRock = () => {
    rocks.push(rock());
  };

  const startGame = () => {
    rockSpawner = setInterval(spawnRock, 10000);
    console.log("Game started", rocks);
  };

  canvas.addEventListener("mousemove", moveMinerLeftRight);
  canvas.addEventListener("click", moveMinerLeftRight);
  canvas.addEventListener("touchstart", moveMinerLeftRight);
  canvas.addEventListener("touchmove", moveMinerLeftRight);

  canvas.addEventListener("click", shoot);
  canvas.addEventListener("mousedown", () => {
    shotter = setInterval(shoot, state.shootCadence);
  });
  canvas.addEventListener("mouseup", () => {
    clearInterval(shotter);
  });

  canvas.addEventListener("touchstart", () => {
    shotter = setInterval(shoot, state.shootCadence);
  });
  canvas.addEventListener("touchend", () => {
    clearInterval(shotter);
  });

  canvas.addEventListener('click', startGame);
</script>
