---
import Button from "./ui/Button.astro";
import Coin from "./ui/Coin.astro";
import Layout from "./ui/Layout.astro";
---

<Layout>
  <div
    class:list={[
      "grid grid-cols-1 grid-rows-[auto_1fr_auto] h-[inherit] w-full",
    ]}
  >
    <img
      src="/games/fluffy/bg/Cartoon_Forest_BG_01.webp"
      alt="bg"
      class="col-start-1 col-end-2 row-start-1 row-end-3 z-0 w-full h-full"
    />
    <div
      class:list={[
        "col-start-1 col-end-2 row-start-1 row-end-2 z-[1]",
        "flex flex-row justify-between items-center p-4",
      ]}
    >
      <Coin />
      <Coin type="gold" position="right" size="lg" />
    </div>
    <div
      class:list={[
        "col-start-1 col-end-2 row-start-2 row-end-3 z-[1]",
        "flex flex-col justify-center items-center gap-8",
      ]}
    >
      <h1 class="text-4xl font-bold text-white">Miner Feber</h1>
      <p class="text-white">Dig for gold and avoid the monsters!</p>
      <Button as="a" href="/games/miner-feber/playing">
        Play
        <span class="icon-[tabler--player-play-filled] w-6 h-6"></span>
      </Button>
    </div>
  </div>
</Layout>

