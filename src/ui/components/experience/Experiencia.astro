---
import SectionHeader from "../SectionHeader.astro";
import experience from "./experience.json";
import { parseDate, getDateDiff } from "@/ui/utils/dates";
---

<section id="experience" class="flex flex-col gap-8">
  <SectionHeader icon="icon-[tabler--briefcase]" title="Experiencia" />
  <div class="flex md:flex-row md:items-end gap-20 overflow-x-auto overflow-y-hidden md:pb-4">
    {
      experience.companies.map((company) => (
        <div class="flex flex-col gap-2 grow max-w-screen-sm min-w-80 pl-4 border-l border-brand-60">
          <h3 class="text-3xl font-bold text-brand-80">{company.name}</h3>
          <p class="text-lg">{company.position}</p>
          <p>
            {parseDate(company.from)} - {company.to === 'now' ? 'Actualidad' : parseDate(company.to)}
          </p>
          <p>
            {getDateDiff(company.from, company.to)}
          </p>
          {company.highlights.length > 0 && (
            <ul class="list-disc list-inside">
              {company.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          )}
        </div>
      ))
    }
  </div>
</section>
