---
import "@fontsource-variable/readex-pro";
import { useTranslation } from "@/i18n";
import CookieConsent from "./CookieConsent.astro";

interface Props {
  title?: string;
}

const { lang } = useTranslation(Astro.url);
const { title } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Software developer Kamilo Vasquez has over 10 years of experience creating solutions that positively impact people's lives. With expertise in web development, mobile apps, desktop apps, and WebAssembly, Kamilo is a self-taught learner with an interest in AI. Seeking job opportunities abroad that require relocation, Kamilo is a highly skilled and motivated professional looking to contribute to a company's success. Contact Kamilo to discuss how he can help your team achieve its goals."
    />
    <title>{title ? `${title} | ` : ""}Kamilo Vasquez</title>
  </head>
  <body>
    <slot />
    <script
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
    ></script>
    <CookieConsent />
  </body>
</html>
