---
import "@fontsource-variable/readex-pro";
import { useTranslation } from "@/i18n";
import CookieConsent from "./CookieConsent.astro";

interface Props {
  title?: string;
}

const { lang } = useTranslation(Astro.url);
const { title } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="I'm Kamilo Vasquez, a passionate software developer with over a decade of experience since 2010. My mission is to create innovative technological solutions that positively impact people's lives. Throughout my career, I've collaborated with international teams on large-scale projects, taking on key roles in web development. My versatility extends beyond web development, also covering mobile and desktop applications. My self-taught approach constantly drives me to explore new technologies, and I'm particularly excited about the world of Artificial Intelligence."
    />
    <meta
      name="keywords"
      content="Software developer, Kamilo Vasquez, web development, mobile applications, desktop applications, innovative technologies, Artificial Intelligence, self-taught, international collaboration, software experience, large-scale projects"
    />
    <meta
      name="author"
      content="Kamilo Vasquez - https://github.com/killoblanco/killoblanco"
    />
    <title>{title ? `${title} | ` : ""}Kamilo Vasquez</title>
  </head>
  <body>
    <slot />
    <script
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
    ></script>
    <CookieConsent />
  </body>
</html>
