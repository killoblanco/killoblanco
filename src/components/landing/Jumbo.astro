---
import Thumbnail from "@/components/assets/Thumbnail.astro";
import SocialNetworks from "@/components/common/SocialNetworks.astro";
import Wave from "@/components/assets/Wave.astro";
import { useTranslation } from "@/i18n";

const { t } = useTranslation(Astro.url);
---

<section
  class="min-h-screen flex flex-col md:flex-row justify-evenly items-center py-16 gap-8"
>
  <div class="flex flex-col gap-4 w-fit">
    <h3 class="inline-flex text-5xl font-semibold gap-4">
      <Wave />
      {t("landing.jumbo.line1")}
    </h3>
    <h1 class="text-7xl md:text-8xl font-bold">
      {t("landing.jumbo.line2")}
    </h1>
    <h2 class="text-5xl md:text-6xl font-semibold">
      {t("landing.jumbo.line3")}
    </h2>
    <SocialNetworks />
  </div>
  <div>
    <Thumbnail />
  </div>
</section>
