---
import { useTranslation } from "@/i18n";
const { t } = useTranslation(Astro.url);
---

<figure
  class="drop-shadow-[theme(spacing.2)_theme(spacing.2)_0_theme(colors.primary)]"
>
  <img
    class="aspect-square w-full min-w-[256px] max-w-[512px] mask mask-hexagon-2"
    src="https://avatars.githubusercontent.com/u/4205975"
    alt={t("landing.jumbo.imgAlt") as unknown as string}
  />
</figure>
